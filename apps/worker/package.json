{
  "name": "@aicos/worker",
  "version": "0.0.0",
  "private": true,
  "description": "AICOS background worker — NestJS 11 standalone host for BullMQ queue processors (extraction pipeline, billing events)",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/bullmq": "^11.0.0",
    "bullmq": "^5.34.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "@aicos/db": "workspace:*",
    "@aicos/shared": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@swc/core": "^1.10.1",
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2"
  }
}
