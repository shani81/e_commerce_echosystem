# =============================================================================
# @aicos/api — environment (copy to .env and fill in real values; never commit .env)
# =============================================================================

NODE_ENV=development

# --- Networking --------------------------------------------------------------
API_PORT=4000
# Comma-separated allowed CORS origins, or '*' for all (dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# --- Datastores --------------------------------------------------------------
# Owner/migration role (superuser) — used by the Prisma CLI; bypasses RLS.
DATABASE_URL=postgresql://aicos:aicos_dev_2026@localhost:5440/aicos?schema=public
# Least-privilege app role (created by `pnpm db:rls`) — RLS IS ENFORCED at runtime.
APP_DATABASE_URL=postgresql://aicos_app:aicos_app_dev_2026@localhost:5440/aicos?schema=public
# Redis for BullMQ (billing queue).
REDIS_URL=redis://localhost:6400

# --- Auth / JWT --------------------------------------------------------------
# Access tokens are RS256. Generate a dev keypair into <repo>/.keys with:
#   pnpm keys:gen
# (auto-loaded). For CI/prod set JWT_PRIVATE_KEY / JWT_PUBLIC_KEY inline instead.
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# Refresh tokens are HS256 (only this API verifies them); use a long random value.
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Billing / Stripe (skeleton) ---------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
