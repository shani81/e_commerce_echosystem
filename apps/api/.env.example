# =============================================================================
# @aicos/api — environment (copy to .env and fill in real values; never commit .env)
# =============================================================================

NODE_ENV=development

# --- Networking --------------------------------------------------------------
API_PORT=4000
# Comma-separated allowed CORS origins, or '*' for all (dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# --- Datastores --------------------------------------------------------------
# PostgreSQL 16+; the app connects as a role under FORCE ROW LEVEL SECURITY.
DATABASE_URL=postgresql://aicos:aicos@localhost:5432/aicos?schema=public
# Redis for BullMQ (billing queue).
REDIS_URL=redis://localhost:6379

# --- Auth / JWT --------------------------------------------------------------
# Use long, random secrets (>= 16 chars). Generate e.g. `openssl rand -base64 48`.
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Billing / Stripe (skeleton) ---------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
