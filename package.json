{
  "name": "aicos",
  "private": true,
  "version": "0.0.0",
  "description": "AI Commerce OS — AI-first multi-tenant e-commerce operating system",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @aicos/db generate",
    "db:push": "pnpm --filter @aicos/db push",
    "db:migrate": "pnpm --filter @aicos/db migrate",
    "db:deploy": "pnpm --filter @aicos/db deploy",
    "db:rls": "pnpm --filter @aicos/db rls",
    "db:seed": "pnpm --filter @aicos/db seed",
    "db:studio": "pnpm --filter @aicos/db studio",
    "db:setup": "pnpm db:generate && pnpm db:push && pnpm db:rls && pnpm db:seed",
    "infra:up": "docker compose -f docker/docker-compose.yml --env-file .env up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
