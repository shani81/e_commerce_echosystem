{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "AICOS NestJS app",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "isolatedModules": false
  }
}
