// =============================================================================
// AICOS — AI Commerce OS — Prisma Schema (DRAFT, Phase 0 planning)
// =============================================================================
// Status: DRAFT for review. No migrations have been generated yet.
//
// Multi-tenancy: shared database, shared schema, `tenantId` on every tenant-
// scoped row, enforced at the DB layer by PostgreSQL Row-Level Security (RLS).
// Prisma does NOT manage RLS policies — those are added via raw-SQL migration
// steps (see prisma/migrations/_rls/ and .ai/database/schema-design.md).
//
// Conventions:
//   - cuid() string primary keys named `id`.
//   - Every tenant-scoped model has `tenantId String` + relation to Tenant,
//     plus @@index([tenantId]) and @@index([tenantId, createdAt]).
//   - Money stored as integer minor units (cents) — never Float.
//   - Soft-delete via `deletedAt DateTime?` on user-facing catalog/commerce rows.
//   - All timestamps UTC; createdAt/updatedAt on every model.
//   - PostgreSQL 16.9+ required (RLS CVE fixes). pgvector + citext extensions.
//
// Target Prisma version: 6.x (datasource `url = env(...)` block, classic
// generator). Validated clean with prisma@6 `validate`. Under Prisma 7 the
// datasource URL moves to prisma.config.ts — adjust at implementation time if
// the monorepo pins 7.x; the model definitions below are unchanged either way.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, vector, citext]
}

