# =============================================================================
# AICOS — environment template. Copy to .env and fill real secrets.
# Local dev defaults match docker/docker-compose.yml and .ai/config/project-ports.json.
# =============================================================================

# --- App ---
NODE_ENV=development
APP_NAME=AICOS

# App URLs / ports (LOCKED — see .ai/config/project-ports.json)
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3100
API_URL=http://localhost:4000
API_PORT=4000
WEB_PORT=3000
ADMIN_PORT=3100
WORKER_PORT=4100
# API CORS allow-list (comma-separated origins; '*' = allow all — dev only)
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# --- PostgreSQL ---
POSTGRES_USER=aicos
POSTGRES_PASSWORD=aicos_dev_2026
POSTGRES_DB=aicos
POSTGRES_HOST=localhost
POSTGRES_PORT=5440
# OWNER/migration role (superuser) — used by the Prisma CLI (push/migrate/rls/seed).
# Bypasses RLS; never used to serve requests.
DATABASE_URL=postgresql://aicos:aicos_dev_2026@localhost:5440/aicos?schema=public
# Least-privilege APP role — used by the API/worker at runtime. RLS IS ENFORCED.
# The role is created by `pnpm db:rls` (packages/db/prisma/sql/roles.sql).
APP_DATABASE_URL=postgresql://aicos_app:aicos_app_dev_2026@localhost:5440/aicos?schema=public

# --- Redis (cache + BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6400
REDIS_URL=redis://localhost:6400

# --- Meilisearch ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=aicos_dev_meili_master_2026

# --- Object storage (S3-compatible: MinIO local / R2 / S3 prod) ---
S3_ENDPOINT=http://localhost:9200
S3_REGION=us-east-1
S3_BUCKET=aicos-media
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_dev_2026
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_dev_2026

# --- Mail (Mailhog local) ---
SMTP_HOST=localhost
SMTP_PORT=1200
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@aicos.local

# --- Auth / JWT ---
# Access tokens use RS256 (asymmetric). Generate a dev keypair into .keys/ with:
#   pnpm keys:gen
# The API auto-loads .keys/jwt_access_*.pem. For CI/prod, set the keys inline
# instead (PEM or base64, single line — `pnpm keys:gen` prints the base64):
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
# Refresh tokens use HS256 (only the API verifies them):
JWT_REFRESH_SECRET=change_me_refresh_secret_min_16_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Local seed credentials (DEV ONLY — see project-dashboard.html) ---
SUPER_ADMIN_EMAIL=superadmin@aicos.local
SUPER_ADMIN_PASSWORD=SuperAdmin!2026
DEMO_ADMIN_EMAIL=admin@aicos.local
DEMO_ADMIN_PASSWORD=Admin!2026

# --- AI providers (provider-abstraction layer) ---
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Google ecosystem (OAuth + APIs) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_MERCHANT_CENTER_ID=

# --- Shipping (aggregator) ---
EASYPOST_API_KEY=
SHIPPO_API_KEY=
